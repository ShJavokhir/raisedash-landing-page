# Raisedash content pipeline, local config. Copy this file to `.env` and fill it in.
# This lives only inside tools/content-pipeline and is gitignored. It is separate
# from the website's own .env.local on purpose.

# AWS Bedrock ------------------------------------------------------------------
# Credentials come from your normal AWS chain (env vars, ~/.aws, or SSO), so you
# usually only need the region here.
AWS_REGION=us-east-1
# If you do NOT use ~/.aws or SSO, set explicit keys instead:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Bedrock model IDs. These defaults target on-demand inference profiles in
# us-east-1. If a call fails with "model not found" or access denied, run
# `npm run check`. It tells you exactly what to set here.
BEDROCK_WRITER_MODEL=us.anthropic.claude-opus-4-8
BEDROCK_CRITIC_MODEL=us.anthropic.claude-sonnet-4-6

# Firecrawl (live research) ----------------------------------------------------
# Get a key at https://www.firecrawl.dev. Used to research primary sources so
# facts are grounded and current.
FIRECRAWL_API_KEY=
# Optional override if you self-host or use a different base URL.
# FIRECRAWL_API_URL=https://api.firecrawl.dev

# Telegram notifications (used by the `auto` command and `--notify`) -----------
# Reuses your existing bot. Leave blank to disable notifications (it no-ops).
TELEGRAM_BOT_TOKEN=
# A chat id to send run alerts to. Falls back to TELEGRAM_CHAT_ID if you set that.
TELEGRAM_CONTENT_CHAT_ID=

# Autonomous shipping (only used by `auto`, which opens a PR) -------------------
# Base branch for PRs. Defaults to master.
# CONTENT_BASE_BRANCH=master
# Commit author for bot PRs.
# GIT_BOT_NAME=raisedash-content-bot
# GIT_BOT_EMAIL=content-bot@raisedash.com
