# Environment Variables Example
# Copy this file to .env.local and fill in the actual values

# JWT Secret for unsubscribe functionality
UNSUBSCRIBE_JWT_SECRET="your-jwt-secret-here"

# Telegram Bot Configuration (for demo request notifications)
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# OPTIONAL: route /start-v2 lead-funnel submissions to a separate chat. Falls back
# to TELEGRAM_CHAT_ID when unset, so you can split these leads out later with no
# code change.
TELEGRAM_LEADS_CHAT_ID=

# WorkOS Configuration (for magic link invitations)
WORKOS_API_KEY=sk_your-workos-api-key
# WORKOS_REDIRECT_URI=https://app.raisedash.com/auth/callback

# Cloudflare R2 (blog image uploads)
# Used by: ./tools/upload-blog-image.sh
CF_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id

# Cloudflare Turnstile (CAPTCHA)
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# IndexNow (instant search engine crawl notifications)
# Used by: POST /api/indexnow (Authorization: Bearer <secret>)
INDEXNOW_SECRET=your-indexnow-secret

# Raisedash backend (NestJS) public base URL. The /start onboarding funnel posts
# leads DIRECTLY to ${NEXT_PUBLIC_API_URL}/v1/public/onboarding (which fires the
# Meta CAPI Lead) so the backend sees the real client IP via CF-Connecting-IP —
# a Vercel proxy hop would mask it. Defaults to https://api.raisedash.com.
# NOTE: the backend must allow this site's origin via CORS_ALLOWED_ORIGINS
# (https://www.raisedash.com,https://raisedash.com).
NEXT_PUBLIC_API_URL=https://api.raisedash.com

# Meta (Facebook/Instagram) Pixel id for the /start and /start-v2 ad funnels.
# OPTIONAL: the funnels work without it; the Pixel just no-ops when unset. This is
# the PUBLIC half — the durable conversion signal is the server-side Conversions
# API (below for /start-v2; in the backend for /start).
NEXT_PUBLIC_META_PIXEL_ID=

# ── Meta Conversions API (server-side) for the /start-v2 funnel ──────────────
# /start-v2 posts to a Next API route (not the backend), so it fires its OWN
# server-side CAPI Lead — deduplicated with the browser Pixel via a shared event
# id. These are SERVER-ONLY (no NEXT_PUBLIC_ prefix): set them in Vercel; they are
# never exposed to the browser. OPTIONAL: without META_PIXEL_ID +
# META_CAPI_ACCESS_TOKEN the server Lead no-ops (funnel stays browser-Pixel-only).
# Same pixel/dataset id as NEXT_PUBLIC_META_PIXEL_ID above.
META_PIXEL_ID=
# System-user access token from Events Manager → Settings → Conversions API. SECRET.
META_CAPI_ACCESS_TOKEN=
# Graph API version for the CAPI endpoint. Defaults to v25.0 if unset.
META_GRAPH_API_VERSION=v25.0
# Events Manager → Test Events code. TESTING ONLY — leave blank in production.
META_CAPI_TEST_EVENT_CODE=

# PostHog — powers /start funnel step drop-off analytics. The browser beacons
# step events to POST /api/ev (see src/lib/funnel-analytics.ts), which forwards
# them to PostHog server-side (so no client SDK has to survive the FB/IG in-app
# browser). OPTIONAL: /api/ev just 204s when the token is unset. The token is the
# publishable `phc_…` project key; the host defaults to https://us.i.posthog.com.
# Names match PostHog's Next.js guide so the same pair also works if the SDK is
# ever added to the marketing pages client-side.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
