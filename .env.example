# Environment Variables Example
# Copy this file to .env.local and fill in the actual values

# JWT Secret for unsubscribe functionality
UNSUBSCRIBE_JWT_SECRET="your-jwt-secret-here"

# Telegram Bot Configuration (for demo request notifications)
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WorkOS Configuration (for magic link invitations)
WORKOS_API_KEY=sk_your-workos-api-key
# WORKOS_REDIRECT_URI=https://app.raisedash.com/auth/callback

# Cloudflare R2 (blog image uploads)
# Used by: ./tools/upload-blog-image.sh
CF_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id

# Cloudflare Turnstile (CAPTCHA)
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# IndexNow (instant search engine crawl notifications)
# Used by: POST /api/indexnow (Authorization: Bearer <secret>)
INDEXNOW_SECRET=your-indexnow-secret

# Raisedash backend (NestJS) base URL — used by the /start onboarding funnel's
# BFF proxy (src/pages/api/public/onboarding.ts) to forward leads to the backend's
# public endpoint (POST /v1/public/onboarding), which fires the Meta CAPI Lead.
RAISEDASH_BACKEND_URL=http://localhost:4000

# Meta (Facebook/Instagram) Pixel id for the /start onboarding funnel only.
# OPTIONAL: the funnel works without it (the server-side Conversions API,
# configured in the backend with the same pixel id + an access token, is the
# durable conversion signal). The Pixel just no-ops when this is unset.
NEXT_PUBLIC_META_PIXEL_ID=
